// بوصلة: قواعد أمان Firestore
// من Firebase Console → Firestore Database → Rules، الصقي هذا الكود كاملاً واضغطي Publish.
// الوصول محمي ببوابة كلمة سر مشتركة عبر Firebase Authentication، لذا القراءة والكتابة مسموحة لأي مستخدم مسجّل دخول فقط.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }
    match /decisions/{decisionId} {
      allow read, write: if request.auth != null;
    }
    match /ideas/{ideaId} {
      allow read, write: if request.auth != null;
    }
  }
}
